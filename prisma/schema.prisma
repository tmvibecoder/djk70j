// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Benutzer (Login)
model User {
  id           String   @id @default(cuid())
  name         String
  email        String?  @unique
  username     String?  @unique
  passwordHash String?
  role         String   @default("admin") // admin, orga
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  salesEntries SalesEntry[]
}

// Produkte (Getränke & Speisen)
model Product {
  id            String   @id @default(cuid())
  name          String
  purchasePrice Float    // Einkaufspreis
  salePrice     Float    // Verkaufspreis
  unit          String   // z.B. "Flasche", "Kiste", "Stück"
  category      String   // z.B. "Bier", "Softdrinks", "Wein", "Speisen"
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  inventories     Inventory[]
  salesEstimates  SalesEstimate[]
  salesEntries    SalesEntry[]
  forecastEntries ForecastEntry[]
}

// Verkaufs-Eintragungen (protokolliert mit Zeitstempel und Benutzer)
model SalesEntry {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int      // Verkaufte Menge in dieser Eintragung
  eventDay  String   // "thursday", "friday", "saturday", "sunday"
  enteredBy String?  // User ID oder Name des Erfassers
  user      User?    @relation(fields: [enteredBy], references: [id], onDelete: SetNull)
  notes     String?  // Optionale Notiz
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([productId])
  @@index([eventDay])
}

// Inventur-Einträge
model Inventory {
  id        String   @id @default(cuid())
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Float
  date      DateTime @default(now())
  eventDay  String   // "thursday", "friday", "saturday", "sunday"
  type      String   // "start", "end", "delivery"
  notes     String?
  createdAt DateTime @default(now())

  @@index([productId])
  @@index([eventDay])
}

// Verkaufsschätzungen
model SalesEstimate {
  id                String  @id @default(cuid())
  productId         String
  product           Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  eventDay          String
  estimatedQuantity Float

  @@unique([productId, eventDay])
}

// Teams (für Watt-Turnier)
model Team {
  id       String @id @default(cuid())
  name     String
  eventDay String @default("thursday")

  participants Participant[]
}

// Teilnehmer
model Participant {
  id        String   @id @default(cuid())
  name      String
  phone     String?
  email     String?
  eventDay  String   @default("thursday")
  paid      Boolean  @default(false)
  teamId    String?
  team      Team?    @relation(fields: [teamId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())

  @@index([teamId])
  @@index([eventDay])
}

// Aufgaben
model Task {
  id          String    @id @default(cuid())
  title       String
  description String?
  detail      String?
  bereichId   String?
  bereich     Bereich?  @relation(fields: [bereichId], references: [id], onDelete: SetNull)
  deadline    DateTime?
  status      String    @default("offen") // "offen", "in_arbeit", "erledigt"
  eventDay    String?
  category    String?
  priority    String    @default("medium") // "low", "medium", "high"
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  assignments TaskAssignment[]

  @@index([bereichId])
  @@index([status])
  @@index([eventDay])
}

// ─── Protokolle ──────────────────────────────────────────────────────────────

// Bereiche aus den Sitzungs-Protokollen (Musik, Getränke, Zelt, …)
model Bereich {
  id              String   @id @default(cuid())
  name            String
  icon            String   // emoji
  verantwortliche String   // Freitext, z.B. "Hundi, Mäx, Festausschuss"
  ordering        Int      @default(0)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tasks       Task[]
  beschluesse Beschluss[]
}

// Personen (Festausschuss-Mitglieder), separat von User für mögliches späteres Login
model Person {
  id         String   @id @default(cuid())
  name       String
  initials   String
  color      String   // hex
  ordering   Int      @default(0)
  isCatchAll Boolean  @default(false) // true für "Helfer x"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  assignments TaskAssignment[]
}

// M:N Task ↔ Person
model TaskAssignment {
  id       String @id @default(cuid())
  taskId   String
  task     Task   @relation(fields: [taskId], references: [id], onDelete: Cascade)
  personId String
  person   Person @relation(fields: [personId], references: [id], onDelete: Cascade)

  @@unique([taskId, personId])
  @@index([taskId])
  @@index([personId])
}

// Beschlüsse aus den Sitzungs-Protokollen
model Beschluss {
  id        String   @id @default(cuid())
  text      String
  bereichId String
  bereich   Bereich  @relation(fields: [bereichId], references: [id], onDelete: Cascade)
  ordering  Int      @default(0)
  createdAt DateTime @default(now())

  @@index([bereichId])
}

// ─── Finanzen ────────────────────────────────────────────────────────────────

// Kostenpositionen (Zeltmiete, Band, Security, etc.)
model CostItem {
  id          String   @id @default(cuid())
  name        String
  projected   Float    @default(0)
  actual      Float?
  dueDate     String   @default("before") // "before", "during", "after", "paid"
  costType    String   @default("fix")    // "fix", "variabel_getraenke", "variabel_sonstig", "unklar"
  status      String   @default("offen")  // "fix", "bezahlt", "zugesagt", "geplant", "geschaetzt", "offen", "klaeren", "bestellen", "anfragen"
  eventDay    String?                     // "thursday", "friday", "saturday", "sunday", null = Allgemein
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// Sponsoren & Zuschüsse
model Sponsor {
  id        String   @id @default(cuid())
  name      String
  amount    Float    @default(0)
  received  Boolean  @default(false)
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// Vereinfachte Prognose (Besucher × Umsatz/Person)
model SimpleForecast {
  id               String @id @default(cuid())
  eventDay         String  // "thursday", "friday", "saturday_day", "saturday_night", "sunday"
  scenario         String  // "pessimistic", "realistic", "optimistic"
  visitors         Int     @default(0)
  revenuePerPerson Float   @default(0)
  entryFee         Float   @default(0)
  costPercent      Float   @default(25)

  @@unique([eventDay, scenario])
}

// Prognose-Szenarien (pro Produkt, pro Tag, pro Szenario) — Legacy
model ForecastEntry {
  id        String @id @default(cuid())
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  eventDay  String  // "thursday", "friday", "saturday", "sunday"
  scenario  String  // "pessimistic", "realistic", "optimistic"
  quantity  Float   @default(0)

  @@unique([productId, eventDay, scenario])
  @@index([eventDay])
  @@index([scenario])
}

// Eintrittsprognose pro Tag und Szenario
model EntryForecast {
  id        String @id @default(cuid())
  eventDay  String  // "thursday", "friday", "saturday", "sunday"
  scenario  String  // "pessimistic", "realistic", "optimistic"
  visitors  Int     @default(0)
  entryFee  Float   @default(0)

  @@unique([eventDay, scenario])
}
